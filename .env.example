# CallClaude Configuration
# Copy this to .env and fill in your values

# ============================================================
# Security (REQUIRED)
# ============================================================

# Secret token for authenticating requests to the bridge server.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This must be added as a custom header on your Retell/Vapi tool URLs.
API_SECRET=

# Comma-separated phone numbers allowed to call your agent (e.g. +14155551234,+14155555678)
# Leave empty to allow all callers (not recommended).
ALLOWED_PHONE_NUMBERS=

# ============================================================
# Retell AI (Voice Agent)
# Sign up at https://app.retell.ai
# ============================================================
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_PHONE_NUMBER=

# ============================================================
# Vapi (Alternative Voice Agent — optional)
# Sign up at https://dashboard.vapi.ai
# ============================================================
VAPI_PRIVATE_KEY=
VAPI_ASSISTANT_ID=

# ============================================================
# Bridge Server
# ============================================================
PORT=3456
NGROK_URL=
CLAUDE_SESSIONS_PATH=claude-sessions
