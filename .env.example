# Claude Orchestrator Configuration
# Copy this to .env and fill in your values

# ============================================================
# Retell AI (Voice Agent)
# Sign up at https://app.retell.ai
# ============================================================
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_PHONE_NUMBER=

# ============================================================
# Vapi (Alternative Voice Agent — optional)
# Sign up at https://dashboard.vapi.ai
# ============================================================
VAPI_PRIVATE_KEY=
VAPI_ASSISTANT_ID=

# ============================================================
# Bridge Server
# ============================================================
PORT=3456
NGROK_URL=

# ============================================================
# Claude Sessions CLI
# Path to claude-sessions if not in PATH
# ============================================================
CLAUDE_SESSIONS_PATH=claude-sessions
